{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2021",
        "sourceMap": true,
        "esModuleInterop": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "skipLibCheck": true,
        "removeComments": true,
        "resolveJsonModule": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "dist-test",
        "test"
    ]
}
